---
import lqip from "../assets/portrait/lqip.txt?raw";
import a1200 from "../assets/portrait/portrait-1200.avif";
import a600 from "../assets/portrait/portrait-600.avif";
import w1200 from "../assets/portrait/portrait-1200.webp";
import w600 from "../assets/portrait/portrait-600.webp";
import BootSequence from "./BootSequence.astro";
import ThemeSwitcher from "./ThemeSwitcher.astro";
// Cutout aspect ratio from source 1792x2390. W=480 H=640 preserves the 3:4 ratio.
const W = 480, H = 640;
const cv = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/resume.pdf`;
---
<section id="hero" class="hero">
  <!-- Per-theme atmosphere washing across the whole first screen. Decorative. -->
  <div class="hero-atmosphere" aria-hidden="true"></div>

  <div class="hero-switcher">
    <ThemeSwitcher />
  </div>

  <div class="hero-inner">
    <div class="hero-copy">
      <BootSequence />
      <h1 class="hero-name">Saransh Seth</h1>
      <span class="hero-name-line" aria-hidden="true"></span>
      <p class="hero-tagline">Senior Frontend Engineer &middot; Design Systems Tech Lead &middot; Melbourne</p>
      <div class="hero-actions">
        <a class="cv-button" href={cv} download="saranshseth-resume.pdf">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download CV
        </a>
      </div>
    </div>

    <div class="hero-portrait" data-hero-portrait>
      <!-- SVG filter defs: decorative per-theme portrait treatments. Hidden from accessibility tree. -->
      <svg width="0" height="0" aria-hidden="true" style="position:absolute">
        <filter id="px-dither"><feColorMatrix type="saturate" values="0"/><feComponentTransfer><feFuncR type="discrete" tableValues="0 0.36 0.9"/><feFuncG type="discrete" tableValues="0.04 0.55 0.95"/><feFuncB type="discrete" tableValues="0 0.2 0.4"/></feComponentTransfer></filter>
        <filter id="bp-edge"><feColorMatrix type="saturate" values="0"/><feConvolveMatrix order="3" kernelMatrix="1 0 -1 2 0 -2 1 0 -1" preserveAlpha="true"/><feComponentTransfer><feFuncR type="linear" slope="0.3"/><feFuncG type="linear" slope="0.76"/><feFuncB type="linear" slope="0.97"/></feComponentTransfer></filter>
      </svg>
      <picture>
        <source type="image/avif" srcset={`${a600.src} 600w, ${a1200.src} 1200w`} sizes="(max-width: 768px) 90vw, 48vw" />
        <source type="image/webp" srcset={`${w600.src} 600w, ${w1200.src} 1200w`} sizes="(max-width: 768px) 90vw, 48vw" />
        <img
          src={w1200.src} width={W} height={H} fetchpriority="high" decoding="async"
          alt="Black and white portrait of Saransh Seth wearing aviator sunglasses, a city skyline reflected in the lenses."
          class="portrait-img" style={`background-image:url(${lqip.trim()});background-size:cover;`}
          onload="this.style.backgroundImage='none'"
        />
      </picture>
      <span class="hero-hint" aria-hidden="true">move to reveal</span>
    </div>
  </div>

  <a class="hero-scroll" href="#approach" aria-label="Scroll to the rest of the page">
    <span>scroll</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
  </a>
</section>

<script>
  // The reveal is ambient, so init once the portrait is on screen (every device, not just
  // pointer ones). Deferred to idle after first paint so it never competes with LCP.
  import { initHeroShader } from "../scripts/hero-shader";
  const host = document.querySelector("[data-hero-portrait]");
  if (host) {
    const start = () => {
      if ("requestIdleCallback" in window) requestIdleCallback(() => initHeroShader(), { timeout: 1500 });
      else setTimeout(() => initHeroShader(), 300);
    };
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) { io.disconnect(); start(); }
      });
      io.observe(host);
    } else {
      start();
    }
  }
</script>
