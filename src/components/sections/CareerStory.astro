---
// Content from the project brief. Enriched with real achievements once the resume is in.
const roles = [
  {
    company: "Intrepid Travel",
    role: "Senior Software Engineer, Acting Tech Lead, Design Systems",
    dates: "Mar 2024 to Present",
    points: [
      "Technical owner of Phoenix, a Vue 3 and TypeScript library of 60+ components on SCSS tokens, shipped to three product teams.",
      "Leading the migration to a layered, white-label architecture: core primitives, theme tokens, and composed components built for theming and clean multi-team distribution.",
      "Built the Figma to code token sync pipeline with Code Connect and the Variables API, and an automated release pipeline with semver, changelogs, and CI publishing.",
      "Developing a Phoenix MCP server that exposes components, tokens, and anti-patterns to AI coding assistants so teams build on-brand with AI.",
      "Set up Playwright visual regression and axe accessibility checks on every component, and onboarded 10+ engineers, cutting ramp-up about 35%.",
      "Two-time internal hackathon winner, both shipped to production, and the team's R&D AI lead.",
    ],
  },
  {
    company: "AmazingCo",
    role: "Full Stack Developer",
    dates: "Jan 2022 to Jan 2024",
    points: [
      "Owned frontend across subscription, collections, scheduling, wishlist, and gift cards in React, Redux, and Next.js. Engagement up 30%.",
      "Integrated five payment methods with Sentry and GA4 wired into each flow. Checkout success up 25%.",
      "Grew organic traffic 20% with dynamic sitemaps on AWS Lambda and server-side rendering, holding Core Web Vitals budgets.",
      "Made Jest and Cypress the team testing standard. Bug reports down 35%.",
    ],
  },
  {
    company: "Nookal",
    role: "Frontend Web Developer",
    dates: "Jun 2017 to Jan 2022",
    points: [
      "Led the move from vanilla JavaScript to React, introducing component architecture and Jest. Revenue grew roughly 1.5x in the years that followed.",
      "Built a shared component library with the lead designer over four years. Those early token conventions shaped how I approach design systems now.",
      "Brought Core Web Vitals and user-flow analytics into roadmap conversations.",
    ],
  },
];
---
<section id="experience" class="career">
  <div class="career-intro chapter-inner">
    <h2 class="chapter-headline" data-career-headline>Experience</h2>
    <span class="chapter-rule" aria-hidden="true"></span>
  </div>

  {roles.map((r) => (
    <article class="career-scene">
      <div class="career-scene-inner">
        <p class="career-dates">{r.dates}</p>
        <h3 class="career-company" data-career-company>{r.company}</h3>
        <p class="career-role">{r.role}</p>
        <ul class="career-points" data-career-points>
          {r.points.map((pt) => <li>{pt}</li>)}
        </ul>
      </div>
    </article>
  ))}

  <!-- Projects slot. Add one or two real projects here when SafeSure / Parichay ship.
       Keep the same scene rhythm as the roles above. Do not populate now. -->
</section>
