---
// Concise website voice, one strong line per role with the proof inside it.
const roles = [
  {
    dates: "2024 to now",
    role: "Senior Engineer, Acting Tech Lead, Design Systems",
    company: "Intrepid Travel",
    line: "I own Phoenix, Intrepid's design system: 60+ components across three teams, now going layered and white-label with a Figma token pipeline and an MCP server that lets AI ship on-brand code.",
  },
  {
    dates: "2022 to 2024",
    role: "Full Stack Developer",
    company: "AmazingCo",
    line: "Owned the storefront end to end. Five payment methods, engagement up a third, checkout up a quarter, organic traffic up a fifth.",
  },
  {
    dates: "2017 to 2022",
    role: "Frontend Web Developer",
    company: "Nookal",
    line: "Took the frontend from vanilla JavaScript to React and built the component library that started my design-systems path.",
  },
];
---
<section id="experience" class="chapter">
  <div class="chapter-inner">
    <h2 class="chapter-headline" data-exp-headline>Experience</h2>
    <span class="chapter-rule" aria-hidden="true"></span>
    <ol class="exp-list">
      {roles.map((r) => (
        <li class="exp-item">
          <p class="exp-meta"><span class="exp-dates">{r.dates}</span>{r.role}</p>
          <h3 class="exp-company">{r.company}</h3>
          <p class="exp-line">{r.line}</p>
        </li>
      ))}
    </ol>

    <!-- Projects slot. Add one or two real projects here when SafeSure / Parichay ship.
         Keep the same row rhythm as the roles above. Do not populate now. -->
  </div>
</section>
