---
// Website voice, not resume bullets. The proof is woven into the sentences.
const roles = [
  {
    dates: "2024 to now",
    company: "Intrepid Travel",
    role: "Senior Engineer, Acting Tech Lead, Design Systems",
    lead: "I own Phoenix, Intrepid's design system. Sixty plus Vue and TypeScript components, three product teams, one source of truth.",
    body: "Right now I am rebuilding it as a layered, white-label system any brand can theme, piping tokens straight from Figma into code, and building an MCP server so AI assistants ship on-brand Phoenix code on their own. Two internal hackathon wins along the way, both in production.",
  },
  {
    dates: "2022 to 2024",
    company: "AmazingCo",
    role: "Full Stack Developer",
    lead: "I owned the storefront end to end: subscriptions, checkout, scheduling, gifting.",
    body: "Five payment methods, with analytics and error tracking through every flow. Engagement up a third, checkout up a quarter, organic traffic up a fifth, performance held to budget the whole way.",
  },
  {
    dates: "2017 to 2022",
    company: "Nookal",
    role: "Frontend Web Developer",
    lead: "Where it started.",
    body: "I moved the frontend from vanilla JavaScript to React, then spent four years building a component library with our designer. Those early token conventions are why I build systems the way I do now.",
  },
];
---
<section id="experience" class="career">
  <div class="career-pin">
    <div class="career-track">
      <article class="career-panel career-title">
        <div class="career-panel-inner">
          <h2 class="chapter-headline" data-career-headline>Experience</h2>
          <span class="chapter-rule" aria-hidden="true"></span>
          <p class="career-lead">Eight years, from a first React migration to leading a design system.</p>
        </div>
      </article>

      {roles.map((r) => (
        <article class="career-panel">
          <div class="career-panel-inner">
            <p class="career-dates">{r.dates}</p>
            <h3 class="career-company" data-career-company>{r.company}</h3>
            <p class="career-role">{r.role}</p>
            <p class="career-lead">{r.lead}</p>
            <p class="career-body">{r.body}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- Projects slot. Add one or two real projects here when SafeSure / Parichay ship.
         Keep the same panel rhythm as the roles above. Do not populate now. -->
  </div>
</section>
