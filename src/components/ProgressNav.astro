---
const sections = [
  { id: "hero", label: "Top" },
  { id: "approach", label: "How I work" },
  { id: "experience", label: "Experience" },
  { id: "lab", label: "System" },
  { id: "credibility", label: "Proof" },
  { id: "contact", label: "Contact" },
];
---
<div class="scroll-progress" aria-hidden="true"><span class="scroll-progress-bar" data-progress></span></div>
<nav class="dot-nav" aria-label="Page sections">
  {sections.map((s) => (
    <a class="dot-nav-item" href={`#${s.id}`} data-dot-for={s.id}>
      <span class="dot-nav-label">{s.label}</span>
      <span class="dot-nav-dot" aria-hidden="true"></span>
    </a>
  ))}
</nav>

<script>
  // Active-section dots. The progress bar fills via a CSS scroll timeline (see
  // .scroll-progress-bar), so only the active-section tracking needs JS here.
  // Orientation aid, so it runs regardless of motion preference.
  const items = Array.from(document.querySelectorAll<HTMLElement>("[data-dot-for]"));
  const setActive = (id: string) => {
    for (const it of items) it.classList.toggle("is-active", it.dataset.dotFor === id);
  };
  if ("IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => { for (const e of entries) if (e.isIntersecting) setActive((e.target as HTMLElement).id); },
      { rootMargin: "-45% 0px -45% 0px" },
    );
    for (const it of items) {
      const el = document.getElementById(it.dataset.dotFor ?? "");
      if (el) io.observe(el);
    }
  }
</script>
